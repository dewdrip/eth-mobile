# Template for Expo app environment variables

# For local development, copy this file, rename it to .env, and fill in the values.
# When deploying live, you'll need to store the vars in your EAS project settings.

# We provide default values for prototyping, but you should
# use your own API keys for production deployment.

# Access these values in your code with process.env.<VARIABLE_NAME>
# Expo exposes vars prefixed with EXPO_PUBLIC_ to the client side.
# See: https://docs.expo.dev/guides/environment-variables/

# Register at https://thirdweb.com/ or the appropriate service to generate your API keys.
EXPO_PUBLIC_THIRDWEB_CLIENT_ID=your-thirdweb-client-id
EXPO_PUBLIC_ALCHEMY_KEY=your-alchemy-key